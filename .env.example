# Required
DISCORD_TOKEN=
GUILD_ID=

# Developer Portal → General Information (optional for gateway bots)
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=

# Bootstrap / runtime
DATABASE_PATH=./data/relay.db
LOG_LEVEL=INFO
PROFILE_FORUM_CHANNEL_ID=
# Optional bootstrap default; prefer /profile set-forum in Discord.
RELAY_LOG_CHANNEL_ID=
MANUAL_RELAY_ENABLED=false
NETWORK_ACCESS_ROLE_NAME=The Network

# top.gg — API token from https://top.gg/bot/YOUR_BOT_ID/webhooks
# Enables automatic server count posting (startup + every 30 minutes).
TOPGG_TOKEN=
